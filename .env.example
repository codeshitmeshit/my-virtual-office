# Virtual Office Configuration
# Copy this file to .env and adjust values for your setup.

# Path to your OpenClaw installation
VO_OPENCLAW_PATH=~/.openclaw

# OpenClaw gateway connection
# Default uses host.docker.internal which works on Linux, Windows, and macOS.
# Override only if your gateway runs on a different host/port.
VO_GATEWAY_URL=ws://host.docker.internal:18789
VO_GATEWAY_HTTP=http://host.docker.internal:18789

# Server ports
VO_PORT=8090
VO_WS_PORT=8091

# Office display name
VO_OFFICE_NAME=Virtual Office

# Codex CLI agents
# Docker containers usually cannot run Codex's bubblewrap sandbox unless they
# are started with extra privileges, so the Docker default is full container access.
VO_CODEX_SANDBOX=danger-full-access
VO_CODEX_APPROVAL_POLICY=never

# Hermes App/API + optional CLI fallback
# In Docker, the Virtual Office container reaches the host Hermes gateway here.
# Hermes must have API_SERVER_ENABLED=true and API_SERVER_KEY set.
VO_HERMES_API_URL=http://host.docker.internal:8642
VO_HERMES_API_KEY=
# Optional only when Hermes CLI/home are installed or mounted inside the container.
# VO_HERMES_HOME=/root/.hermes
# VO_HERMES_BIN=/root/.local/bin/hermes

# Weather widget location (optional, e.g. "New+York,NY")
VO_WEATHER_LOCATION=

# Agent Browser VNC password (if using the optional browser service)
# BROWSER_VNC_PASSWORD=changeme
