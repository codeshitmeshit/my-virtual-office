# Virtual Office Configuration
# Copy this file to .env and adjust values for your setup.

# Path to your OpenClaw installation (optional)
VO_OPENCLAW_PATH=~/.openclaw

# OpenClaw gateway connection (optional; local mode reads ~/.openclaw/openclaw.json gateway.port)
# VO_GATEWAY_URL=ws://localhost:18790
# VO_GATEWAY_HTTP=http://localhost:18790

# Server ports
# VO_PORT=8090
# VO_WS_PORT=8091
# Public same-origin WebSocket path configured in your reverse proxy
# VO_WS_PATH=/ws
# Optional stable token for session and credential-management actions. When
# omitted, the server prints a random token at startup for the UI prompt.
# VO_MANAGEMENT_TOKEN=replace-with-a-long-random-token

# Office display name
# VO_OFFICE_NAME=Virtual Office

# Codex CLI agents
# Local default: write inside the workspace and ask before broader access.
VO_CODEX_SANDBOX=workspace-write
VO_CODEX_APPROVAL_POLICY=on-request

# Hermes API Server + optional Desktop Backend + optional CLI fallback
# Hermes must have API_SERVER_ENABLED=true and API_SERVER_KEY set.
VO_HERMES_API_ENABLED=true
VO_HERMES_API_URL=http://127.0.0.1:8642
VO_HERMES_API_KEY=
# Optional Desktop Backend mode. Use the loopback URL of the local Desktop app.
# VO_HERMES_DESKTOP_URL=http://127.0.0.1:62353
# VO_HERMES_DESKTOP_TCP_HOST=127.0.0.1
# VO_HERMES_DESKTOP_TCP_PORT=62353
# VO_HERMES_DESKTOP_HOST_HEADER=127.0.0.1:62353
# VO_HERMES_DESKTOP_LOG_PATH=~/.hermes/logs/desktop.log
# VO_HERMES_HOME=~/.hermes
# VO_HERMES_BIN=~/.local/bin/hermes

# Optional Hermes Messaging Gateway platform mode. This is separate from
# Desktop Backend/API Server mode: Hermes gateway polls Virtual Office and
# posts replies back as a messaging platform.
# VO_HERMES_PLATFORM_ENABLED=true
# VO_HERMES_PLATFORM_TOKEN=replace-with-a-long-random-token
# VO_HERMES_PLATFORM_AGENT_ID=hermes-gateway

# Weather widget location (optional, e.g. "New+York,NY")
# VO_WEATHER_LOCATION=

# Agent Browser panel (optional)
# Enable the toolbar/browser panel entry at startup.
# Requires a licensed/unlocked feature gate and reachable browser endpoints.
VO_BROWSER_PANEL=true
VO_CDP_URL=http://127.0.0.1:9224
VO_VIEWER_URL=https://localhost:6901

# PC performance panel (optional)
VO_PC_METRICS_ENABLED=true
VO_PC_METRICS_URL=http://127.0.0.1:8099

# API usage panel
VO_API_USAGE=false

# Agent-managed VO project authoring.
# Agents still must read the VO skill entry, show a natural-language proposal,
# and wait for explicit confirmation before creating a real project.
VO_AGENT_PROJECT_AUTHORING_ENABLED=true

# Hermes native API (optional)
# VO_HERMES_ENABLED=1
# VO_HERMES_HOME=~/.hermes
# VO_HERMES_BIN=~/.local/bin/hermes
# VO_HERMES_API_ENABLED=1
# VO_HERMES_PREFER_API=0
# VO_HERMES_API_URL=http://127.0.0.1:8642
# VO_HERMES_API_KEY=

# Codex live bridge and native agents (optional)
# VO_CODEX_ENABLED=1
# VO_CODEX_HOME=~/.codex
# VO_CODEX_BIN=codex
# VO_CODEX_WORKSPACE=/path/to/repo
# VO_CODEX_WORKSPACE_ROOT=/data/codex-agents
# VO_CODEX_MAIN_WORKSPACE=/data/codex-main
# VO_CODEX_MODEL=
# VO_CODEX_SANDBOX=workspace-write
# VO_CODEX_APPROVAL_POLICY=never
# VO_CODEX_INCLUDE_MAIN=1
# VO_CODEX_INCLUDE_NATIVE_AGENTS=1
# VO_CODEX_REGISTER_NATIVE_AGENTS=1
# Reasoning summary: auto, concise, detailed, or none (default: concise)
# VO_CODEX_REASONING_SUMMARY=concise
# VO_CODEX_BRIDGE_URL=http://127.0.0.1:4501
# VO_CODEX_REPLY_TEXT=deterministic test reply

# Claude Code native agents (optional)
# VO_CLAUDE_CODE_ENABLED=1
# VO_CLAUDE_CODE_HOME=~/.claude
# VO_CLAUDE_CODE_BIN=claude
# VO_CLAUDE_CODE_WORKSPACE=/path/to/repo
# VO_CLAUDE_CODE_WORKSPACE_ROOT=/data/claude-code-agents
# VO_CLAUDE_CODE_MAIN_WORKSPACE=/data/claude-code-main
# VO_CLAUDE_CODE_MODEL=
# VO_CLAUDE_CODE_PERMISSION_MODE=acceptEdits
# VO_CLAUDE_CODE_INCLUDE_MAIN=1
# VO_CLAUDE_CODE_INCLUDE_NATIVE_AGENTS=1
# VO_CLAUDE_CODE_REGISTER_NATIVE_AGENTS=1

# Feishu notifications and card actions (optional)
# Configure either a legacy bot webhook or an app credential + receive ID.
# App credentials also enable card action callbacks through Feishu long connection.
# VO_FEISHU_NOTIFICATION_ENABLED=1
# VO_FEISHU_NOTIFICATION_WEBHOOK=
# VO_FEISHU_APP_ID=
# VO_FEISHU_APP_SECRET=
# VO_FEISHU_RECEIVE_ID_TYPE=chat_id
# VO_FEISHU_RECEIVE_ID=

# Exact chat control messages. Both switches default off. Enable VO first;
# Feishu commands require both switches to be enabled.
# VO_CHAT_SLASH_COMMANDS_ENABLED=0
# VO_FEISHU_CHAT_SLASH_COMMANDS_ENABLED=0
