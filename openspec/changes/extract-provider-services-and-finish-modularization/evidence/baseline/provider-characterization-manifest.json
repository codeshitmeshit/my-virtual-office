  "scenarios": [
    {"id": "route-request-response-status", "commands": ["provider-contract", "codex-runs", "claude-runs", "hermes-native"], "covers": "accepted fields, stable result/status mapping, provider path, missing/invalid input"},
    {"id": "run-start-poll-terminal", "commands": ["codex-runs", "claude-runs", "hermes-native"], "covers": "start identity, background state, progress, exactly one normal terminal event"},
    {"id": "run-failure-timeout-unavailable", "commands": ["provider-runtime", "codex-provider", "claude-provider", "hermes-api", "hermes-native"], "covers": "timeout cleanup, unavailable binary/API and provider-scoped failure"},
    {"id": "conversation-continuation-reset-isolation", "commands": ["chat-sessions", "chat-history", "codex-provider", "claude-provider", "hermes-native"], "covers": "native IDs, old histories, reset/delete and cross-conversation isolation"},
    {"id": "approval-registration-decision-replay", "commands": ["hermes-native", "codex-provider", "feishu"], "covers": "pending identity, provider decision, Feishu action, notification dedupe and invalid decisions"},
    {"id": "cancellation", "commands": ["codex-runs", "hermes-native", "claude-provider"], "covers": "provider stop/interrupt and compatible cancelled terminal"},
    {"id": "sse-after-last-event-heartbeat-recovery", "commands": ["bridge-contract", "provider-sse-static", "codex-sse-static", "claude-sse-static"], "covers": "Last-Event-ID, after, event framing, 10-second heartbeat, snapshot, history recovery and late terminal"},
    {"id": "concurrent-scopes", "commands": ["bridge-contract", "provider-runtime"], "covers": "100 isolated scopes, monotonic event IDs, request routing and no cross-scope payload"},
    {"id": "project-meeting-feishu-callers", "commands": ["project-port", "meeting-port", "feishu"], "covers": "Provider ports used by Project Execution, Meeting and Feishu integrations"},
    {"id": "fixed-capacity-performance", "commands": ["performance"], "covers": "1/20/100 runs and 10/1,000/4,000 events, call counts, retained bytes, latency and scan upper bounds"},
    {"id": "generated-ownership-evidence", "commands": ["inventory-contract", "inventory-reproducibility"], "covers": "caller/writer map, capability matrix, aliases, approval bounds and transport candidates"}
  ],
  "knownBaselineRisks": [
    {"id": "terminal-race-no-cas", "current": "ProviderRunBridge update/emit has no generation or terminal compare-and-set", "required": "Sections 2-4 add fenced single-terminal ownership and cancel-vs-complete concurrency tests"},
